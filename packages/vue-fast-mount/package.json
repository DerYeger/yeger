{
  "name": "vue-fast-mount",
  "version": "0.0.3",
  "description": "Vite plugin for faster mounting of Vue components in Vitest.",
  "keywords": [
    "library",
    "vite-plugin",
    "vue"
  ],
  "homepage": "https://github.com/DerYeger/yeger/tree/main/packages/vue-fast-mount",
  "bugs": {
    "url": "https://github.com/DerYeger/yeger/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jan Müller",
    "url": "https://github.com/DerYeger"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DerYeger/yeger.git",
    "directory": "packages/vue-fast-mount"
  },
  "funding": "https://github.com/sponsors/DerYeger",
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin/index.d.mts",
        "default": "./dist/plugin/index.mjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "publint": "publint run --strict",
    "test": "vitest",
    "typecheck": "vue-tsc"
  },
  "dependencies": {
    "@yeger/streams": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@vue/test-utils": "catalog:",
    "@yeger/tsconfig": "workspace:*",
    "@yeger/vitest-utils": "workspace:*",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@vue/test-utils": "^2.0.0",
    "vite": "^7.0.0",
    "vue": "^3.0.0"
  }
}
