{
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "nextjs",
    "oxc",
    "import",
    "jsdoc",
    "jsx-a11y",
    "node",
    "promise",
    "vitest",
    "vue"
  ],
  "settings": {
    "jsdoc": {
      "tagNamePreference": {
        "defaultValue": "defaultValue",
        "remarks": "remarks"
      }
    }
  }
}
