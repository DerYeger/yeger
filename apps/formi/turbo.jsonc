{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "test"],
      "outputs": [".nuxt/**", ".output/**", "dist/**"],
    },
    "typecheck": {
      // Prevents race conditions due to parallel executions, but dependency is not strictly required
      "dependsOn": ["build", "generate"],
    },
  },
}
