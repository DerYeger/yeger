{
  "$schema": "./node_modules/syncpack/schema.json",
  "versionGroups": [
    {
      "label": "Ignored",
      "dependencyTypes": [
        "peer"
      ],
      "isIgnored": true
    },
    {
      "label": "Local",
      "dependencies": [
        "@yeger/*",
        "d3-graph-controller",
        "key-hierarchy",
        "resumon",
        "vecti",
        "vite-plugin-lib",
        "vue-fast-mount",
        "vue-marmoset-viewer"
      ],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Turbo",
      "dependencies": [
        "turbo"
      ]
    },
    {
      "label": "External",
      "pinVersion": "catalog:"
    }
  ]
}